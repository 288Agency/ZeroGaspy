# Configuration ZeroGaspy

# Email pour recevoir les feedbacks
EXPO_PUBLIC_FEEDBACK_EMAIL=contact@288agency.com

# Configuration Resend (optionnel - pour backend)
# Obtenez votre clé API sur https://resend.com
EXPO_PUBLIC_FEEDBACK_API_URL=https://votre-projet.railway.app/api/feedback

# Exemples d'URLs selon la plateforme :
# Railway: https://votre-projet.railway.app/api/feedback
# Render: https://votre-projet.onrender.com/api/feedback
# Vercel: https://votre-projet.vercel.app/api/feedback

# Pour deployer le serveur, voir server/README.md

# ===================================
# Google Cloud Vision API (OCR)
# ===================================
# Necessaire pour le scan de tickets de caisse
#
# Pour obtenir une cle API:
# 1. Allez sur https://console.cloud.google.com
# 2. Creez un projet ou selectionnez-en un existant
# 3. Activez l'API "Cloud Vision API"
# 4. Allez dans "APIs & Services" > "Credentials"
# 5. Cliquez sur "Create Credentials" > "API Key"
# 6. Copiez la cle generee ci-dessous
#
# Tarification: 1000 requetes gratuites/mois, puis $1.50/1000 requetes
# https://cloud.google.com/vision/pricing
#
EXPO_PUBLIC_GOOGLE_VISION_API_KEY=votre_cle_api_google_vision
