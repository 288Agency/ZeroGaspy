# Clé API Resend (obtenez-la sur https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Email qui recevra les feedbacks
FEEDBACK_RECIPIENT_EMAIL=votre-email@example.com

# Email d'envoi (utilisez votre domaine vérifié dans Resend)
RESEND_FROM_EMAIL=ZeroGaspy <onboarding@resend.dev>

# Port du serveur (optionnel, par défaut 3000)
PORT=3000

# Environnement (development ou production)
NODE_ENV=production

